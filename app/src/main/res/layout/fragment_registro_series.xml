<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Tirador -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/primary"
        android:backgroundTint="@color/borde_handle" />

    <!-- Nombre del ejercicio -->
    <TextView
        android:id="@+id/tv_nombre_ejercicio_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sentadilla con barra"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" />

    <!-- Fecha -->
    <TextView
        android:id="@+id/tv_fecha_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/texto_secundario"
        android:layout_marginBottom="20dp" />

    <!-- Lista de series -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_series"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <!-- Botón añadir serie -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_añadir_serie"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/series_anadir"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:strokeColor="@color/primary"
        android:textColor="@color/primary" />

    <!-- Botón guardar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_guardar_sesion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/series_guardar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp" />

</LinearLayout>