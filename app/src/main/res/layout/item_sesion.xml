<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Cabecera: fecha + rutina -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_fecha_sesion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tv_nombre_rutina_sesion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rutina Pecho"
                    android:textSize="13sp"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_num_ejercicios_sesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 ejercicios"
                android:textSize="13sp"
                android:textColor="#888888" />

            <!-- ← NUEVO: botón eliminar sesión completa -->
            <ImageButton
                android:id="@+id/btn_eliminar_sesion"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#FF5252" />

            <ImageView
                android:id="@+id/iv_expandir"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#888888" />

        </LinearLayout>

        <!-- Lista de ejercicios expandible -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ejercicios_sesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>