<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/primary" />

            <EditText
                android:id="@+id/et_buscar_ejercicio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="@string/ejercicios_buscar_hint"
                android:inputType="text"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textColorHint="@color/texto_hint" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Filtros Horizontales -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/grupo_filtros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_todos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_todos"
                android:checked="true"
                app:chipBackgroundColor="@color/primary"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_pecho"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_pecho" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_espalda"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_espalda" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_hombros"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_hombros" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_brazos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_brazos" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_antebrazos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_antebrazos" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_piernas"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_piernas" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_gemelos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_gemelos" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_cintura"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_cintura" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_cuello"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_cuello" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filtro_cardio"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filtro_cardio" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Lista de Ejercicios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEjercicios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

</LinearLayout>